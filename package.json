{
  "name": "card-cloud",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"db,next\" --prefix-colors \"cyan,green\" \"npm run dev:db\" \"npm run dev:app\"",
    "dev:db": "prisma dev",
    "dev:app": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "service:start": "pm2 start ecosystem.config.js",
    "service:stop": "pm2 stop ecosystem.config.js",
    "service:restart": "pm2 restart ecosystem.config.js",
    "service:status": "pm2 status",
    "service:logs": "pm2 logs",
    "db:studio": "npx prisma studio",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@react-email/tailwind": "^2.0.7",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
