# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── Database ──────────────────────────────────────────────────────────────────
# Local development (Prisma managed Postgres — run `npx prisma dev` to start)
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=YOUR_LOCAL_KEY"
# Hosted Postgres (use this format when deploying)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a secret: run `openssl rand -base64 32` in your terminal
NEXTAUTH_SECRET="your-secret-here"
# The full URL of your app (no trailing slash)
NEXTAUTH_URL="http://localhost:3001"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com
# Authorized redirect URI: http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
